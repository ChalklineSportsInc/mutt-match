# Copy this file to .env for local development
# On Railway, set these in the Variables tab

# REQUIRED in production — change this to a long random string
JWT_SECRET=change-this-to-a-long-random-secret

# Path for the SQLite database file
# On Railway with a volume mounted at /data, set this to /data/mutt-match.db
DATABASE_PATH=./mutt-match.db

# Port (Railway sets this automatically — don't change)
PORT=3000
